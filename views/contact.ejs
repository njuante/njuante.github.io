<!-- Contact Section -->
<section class="mx-auto max-w-6xl px-4 md:px-6 py-16 md:py-24">
  <div class="grid md:grid-cols-2 gap-12">
    <div>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight">Contacto</h1>
      <p class="mt-4 text-slate-600 dark:text-slate-300">
        ¿Tienes algún proyecto o propuesta interesante? Puedes contactarme a través del formulario o usar alguno de los siguientes canales:
      </p>
      <div class="mt-6 space-y-4">
        <div class="flex items-center gap-3">
          <div class="flex-none grid h-10 w-10 place-items-center rounded-full bg-primary-100 dark:bg-primary-900/30">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="text-primary-600" viewBox="0 0 16 16">
              <path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0ZM4.5 7.5a.5.5 0 0 0 0 1h5.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3a.5.5 0 0 0 0-.708l-3-3a.5.5 0 1 0-.708.708L10.293 7.5H4.5Z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-medium">LinkedIn</h3>
            <p class="text-sm text-slate-600 dark:text-slate-400">
              <a href="https://linkedin.com/in/juannunez" class="hover:text-primary-600">linkedin.com/in/juannunez</a>
            </p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="flex-none grid h-10 w-10 place-items-center rounded-full bg-primary-100 dark:bg-primary-900/30">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="text-primary-600" viewBox="0 0 16 16">
              <path d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-medium">Twitter</h3>
            <p class="text-sm text-slate-600 dark:text-slate-400">
              <a href="https://twitter.com/njuante" class="hover:text-primary-600">@njuante</a>
            </p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="flex-none grid h-10 w-10 place-items-center rounded-full bg-primary-100 dark:bg-primary-900/30">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="text-primary-600" viewBox="0 0 16 16">
              <path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4Zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1H2Zm13 2.383-4.708 2.825L15 11.105V5.383Zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741ZM1 11.105l4.708-2.897L1 5.383v5.722Z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-medium">Email</h3>
            <p class="text-sm text-slate-600 dark:text-slate-400">
              <a href="mailto:hola@njuante.dev" class="hover:text-primary-600">hola@njuante.dev</a>
            </p>
          </div>
        </div>
      </div>
    </div>
    <div>
      <form id="contactForm" class="rounded-2xl border border-slate-200 dark:border-slate-800 p-6 shadow-soft">
        <div class="mb-4">
          <label for="nombre" class="mb-2 block text-sm font-medium">Nombre</label>
          <input type="text" id="nombre" name="nombre" class="block w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 px-4 py-3 text-sm focus:border-primary-500 focus:ring-primary-500">
        </div>
        <div class="mb-4">
          <label for="email" class="mb-2 block text-sm font-medium">Email</label>
          <input type="email" id="email" name="email" class="block w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 px-4 py-3 text-sm focus:border-primary-500 focus:ring-primary-500">
        </div>
        <div class="mb-4">
          <label for="asunto" class="mb-2 block text-sm font-medium">Asunto</label>
          <input type="text" id="asunto" name="asunto" class="block w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 px-4 py-3 text-sm focus:border-primary-500 focus:ring-primary-500">
        </div>
        <div class="mb-4">
          <label for="mensaje" class="mb-2 block text-sm font-medium">Mensaje</label>
          <textarea id="mensaje" name="mensaje" rows="4" class="block w-full rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 px-4 py-3 text-sm focus:border-primary-500 focus:ring-primary-500"></textarea>
        </div>
        <button type="submit" class="inline-flex items-center gap-2 rounded-xl bg-primary-600 px-5 py-3 text-white hover:bg-primary-700">
          Enviar mensaje
        </button>
      </form>
    </div>
  </div>
</section>

<script src="/assets/js/form.js"></script>
