---
import MainLayout from "../layouts/MainLayout.astro";
import Button from "../components/Button.astro";

interface BlogPost {
  title: string;
  excerpt: string;
  date: string;
  image: string;
  slug: string;
  tags: string[];
  author: string;
  readTime: string;
}

// This would typically come from a CMS or markdown files
const blogPosts: BlogPost[] = [
  {
    title: "Creating Responsive Layouts with CSS Grid",
    excerpt: "Learn how to build modern, responsive layouts using CSS Grid that work across all screen sizes.",
    date: "August 28, 2023",
    image: "/images/blog/css-grid.jpg",
    slug: "responsive-layouts-css-grid",
    tags: ["CSS", "Web Design", "Responsive"],
    author: "Juan",
    readTime: "6 min read"
  },
  {
    title: "Getting Started with React Hooks",
    excerpt: "A comprehensive guide to using React Hooks to manage state and side effects in functional components.",
    date: "July 15, 2023",
    image: "/images/blog/react-hooks.jpg",
    slug: "getting-started-react-hooks",
    tags: ["React", "JavaScript", "Frontend"],
    author: "Juan",
    readTime: "8 min read"
  },
  {
    title: "Optimizing Website Performance",
    excerpt: "Essential techniques to improve your website's loading speed and overall performance.",
    date: "June 3, 2023",
    image: "/images/blog/performance.jpg",
    slug: "optimizing-website-performance",
    tags: ["Performance", "Web Development", "Optimization"],
    author: "Juan",
    readTime: "5 min read"
  },
  {
    title: "Introduction to Astro Framework",
    excerpt: "Explore the Astro framework for building lightning-fast websites with your favorite UI components.",
    date: "May 17, 2023",
    image: "/images/blog/astro.jpg",
    slug: "introduction-to-astro",
    tags: ["Astro", "JavaScript", "Web Development"],
    author: "Juan",
    readTime: "7 min read"
  },
  {
    title: "Building a Dark Mode Toggle with Tailwind CSS",
    excerpt: "Step-by-step guide to implementing a dark mode toggle in your website using Tailwind CSS.",
    date: "April 22, 2023",
    image: "/images/blog/dark-mode.jpg",
    slug: "dark-mode-toggle-tailwind",
    tags: ["Tailwind CSS", "JavaScript", "UI/UX"],
    author: "Juan",
    readTime: "4 min read"
  },
  {
    title: "Mastering CSS Animations",
    excerpt: "Tips and techniques for creating smooth, performant animations using pure CSS.",
    date: "March 10, 2023",
    image: "/images/blog/css-animations.jpg",
    slug: "mastering-css-animations",
    tags: ["CSS", "Animations", "Frontend"],
    author: "Juan",
    readTime: "6 min read"
  }
];
---

<MainLayout title="Blog | Juan's Portfolio" description="Articles and insights on web development, design, and technology.">
  <div class="container mx-auto px-4 py-16">
    <header class="max-w-3xl mx-auto text-center mb-16">
      <h1 
        class="text-4xl sm:text-5xl font-bold mb-6 gradient-text inline-block" 
        data-aos="fade-up"
      >
        My Blog
      </h1>
      <p 
        class="text-lg text-gray-700 dark:text-gray-300" 
        data-aos="fade-up" 
        data-aos-delay="100"
      >
        Thoughts, tutorials, and insights on web development, design, and technology.
      </p>
    </header>
    
    <!-- Search and Filters -->
    <div 
      class="max-w-3xl mx-auto mb-12 flex flex-col sm:flex-row gap-4"
      data-aos="fade-up"
      data-aos-delay="200"
    >
      <div class="relative flex-grow">
        <input 
          type="text" 
          placeholder="Search articles..." 
          class="w-full px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-primary-500 pl-10"
        />
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
      
      <select class="px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-primary-500">
        <option value="">All Categories</option>
        <option value="Web Development">Web Development</option>
        <option value="Design">Design</option>
        <option value="JavaScript">JavaScript</option>
        <option value="CSS">CSS</option>
      </select>
    </div>
    
    <!-- Blog Posts Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {blogPosts.map((post, index) => (
        <article 
          class="glass-panel overflow-hidden flex flex-col h-full transform transition-all hover:-translate-y-1 hover:shadow-xl"
          data-aos="fade-up"
          data-aos-delay={index * 100 + 200}
        >
          <a href={`/blog/${post.slug}`} class="block relative aspect-video overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-primary-500/10 to-secondary-500/10 z-10"></div>
            <img 
              src={post.image} 
              alt={post.title}
              class="w-full h-full object-cover transform transition-transform hover:scale-105"
            />
          </a>
          
          <div class="p-6 flex flex-col flex-grow">
            <div class="mb-3 flex items-center justify-between text-sm text-gray-600 dark:text-gray-400">
              <time datetime="2023-08-28">{post.date}</time>
              <span>{post.readTime}</span>
            </div>
            
            <h3 class="text-xl font-bold mb-2">
              <a href={`/blog/${post.slug}`} class="text-gray-900 dark:text-white hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
                {post.title}
              </a>
            </h3>
            
            <p class="text-gray-700 dark:text-gray-300 mb-4 flex-grow">
              {post.excerpt}
            </p>
            
            <div class="flex flex-wrap gap-2 mb-4">
              {post.tags.map(tag => (
                <span class="text-xs px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-800 dark:text-gray-200 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
            
            <Button href={`/blog/${post.slug}`} variant="ghost" class="text-primary-600 dark:text-primary-400 self-start">
              Read More
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </Button>
          </div>
        </article>
      ))}
    </div>
  </div>
</MainLayout>

<script>
  // Simple search functionality - can be expanded
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.querySelector('input[type="text"]');
    const categorySelect = document.querySelector('select');
    const articles = document.querySelectorAll('article');
    
    const filterArticles = () => {
      const searchTerm = (searchInput as HTMLInputElement)?.value.toLowerCase() || '';
      const category = (categorySelect as HTMLSelectElement)?.value || '';
      
      articles.forEach(article => {
        const title = article.querySelector('h3')?.textContent?.toLowerCase() || '';
        const excerpt = article.querySelector('p')?.textContent?.toLowerCase() || '';
        const tags = Array.from(article.querySelectorAll('.rounded-full')).map(tag => tag.textContent?.toLowerCase() || '');
        
        const matchesSearch = title.includes(searchTerm) || excerpt.includes(searchTerm);
        const matchesCategory = !category || tags.includes(category.toLowerCase());
        
        if (matchesSearch && matchesCategory) {
          article.style.display = '';
        } else {
          article.style.display = 'none';
        }
      });
    };
    
    searchInput?.addEventListener('input', filterArticles);
    categorySelect?.addEventListener('change', filterArticles);
  });
</script>
