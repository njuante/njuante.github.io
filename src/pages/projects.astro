---
import MainLayout from "../layouts/MainLayout.astro";
import Button from "../components/Button.astro";

interface Project {
  title: string;
  description: string;
  tags: string[];
  image: string;
  link: string;
  github?: string;
  featured?: boolean;
}

const projects: Project[] = [
  {
    title: "Modern E-commerce Platform",
    description: "A full-featured e-commerce solution with product catalog, cart system, user authentication, and payment processing.",
    tags: ["React", "Node.js", "MongoDB", "Stripe"],
    image: "/images/projects/ecommerce.jpg",
    link: "/projects/ecommerce",
    github: "https://github.com/njuante/ecommerce-platform",
    featured: true
  },
  {
    title: "Health & Fitness Tracker",
    description: "Mobile-responsive application for tracking workouts, nutrition, and health metrics with data visualization.",
    tags: ["Vue.js", "Firebase", "Chart.js", "PWA"],
    image: "/images/projects/fitness.jpg",
    link: "/projects/fitness-tracker",
    github: "https://github.com/njuante/fitness-tracker",
    featured: true
  },
  {
    title: "Smart Home Dashboard",
    description: "IoT control dashboard for managing smart home devices with real-time monitoring and automation features.",
    tags: ["React", "GraphQL", "WebSockets", "IoT"],
    image: "/images/projects/smart-home.jpg",
    link: "/projects/smart-home",
    github: "https://github.com/njuante/smart-home-dashboard",
    featured: true
  },
  {
    title: "Personal Blog Platform",
    description: "A customizable blogging platform with Markdown support, categories, tags, and a responsive design.",
    tags: ["Astro", "Tailwind CSS", "Markdown", "JAMstack"],
    image: "/images/projects/blog.jpg",
    link: "/projects/blog-platform",
    github: "https://github.com/njuante/blog-platform"
  },
  {
    title: "Task Management App",
    description: "A productive task manager with features like drag-and-drop, priorities, due dates, and team collaboration.",
    tags: ["React", "Redux", "Firebase", "Material UI"],
    image: "/images/projects/tasks.jpg",
    link: "/projects/task-manager",
    github: "https://github.com/njuante/task-manager"
  },
  {
    title: "Weather Dashboard",
    description: "A weather forecast application with current conditions, hourly and daily forecasts, and location search.",
    tags: ["JavaScript", "API Integration", "CSS3", "Responsive Design"],
    image: "/images/projects/weather.jpg",
    link: "/projects/weather-app",
    github: "https://github.com/njuante/weather-dashboard"
  },
  {
    title: "Portfolio Website Template",
    description: "A customizable portfolio template for developers and designers with project showcase and contact form.",
    tags: ["HTML5", "CSS3", "JavaScript", "Responsive"],
    image: "/images/projects/portfolio.jpg",
    link: "/projects/portfolio-template",
    github: "https://github.com/njuante/portfolio-template"
  },
  {
    title: "Recipe Sharing Platform",
    description: "A community-driven recipe sharing website with search, filtering, ratings, and user profiles.",
    tags: ["Node.js", "Express", "MongoDB", "EJS"],
    image: "/images/projects/recipe.jpg",
    link: "/projects/recipe-app",
    github: "https://github.com/njuante/recipe-platform"
  }
];
---

<MainLayout title="Projects | Juan's Portfolio" description="Explore my web development projects including e-commerce solutions, mobile apps, and more.">
  <div class="container mx-auto px-4 py-16">
    <header class="max-w-3xl mx-auto text-center mb-16">
      <h1 
        class="text-4xl sm:text-5xl font-bold mb-6 gradient-text inline-block" 
        data-aos="fade-up"
      >
        My Projects
      </h1>
      <p 
        class="text-lg text-gray-700 dark:text-gray-300" 
        data-aos="fade-up" 
        data-aos-delay="100"
      >
        A collection of my work spanning web applications, mobile-responsive sites, and design projects.
      </p>
    </header>
    
    <!-- Filter/Categories (can be expanded later) -->
    <div 
      class="flex flex-wrap justify-center gap-4 mb-12"
      data-aos="fade-up"
      data-aos-delay="200"
    >
      <button class="px-4 py-2 rounded-full bg-primary-600 text-white font-medium">All</button>
      <button class="px-4 py-2 rounded-full bg-gray-200 dark:bg-gray-800 text-gray-800 dark:text-gray-200 font-medium hover:bg-gray-300 dark:hover:bg-gray-700 transition">Frontend</button>
      <button class="px-4 py-2 rounded-full bg-gray-200 dark:bg-gray-800 text-gray-800 dark:text-gray-200 font-medium hover:bg-gray-300 dark:hover:bg-gray-700 transition">Backend</button>
      <button class="px-4 py-2 rounded-full bg-gray-200 dark:bg-gray-800 text-gray-800 dark:text-gray-200 font-medium hover:bg-gray-300 dark:hover:bg-gray-700 transition">Full Stack</button>
      <button class="px-4 py-2 rounded-full bg-gray-200 dark:bg-gray-800 text-gray-800 dark:text-gray-200 font-medium hover:bg-gray-300 dark:hover:bg-gray-700 transition">Design</button>
    </div>
    
    <!-- Project Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map((project, index) => (
        <div 
          class="glass-panel overflow-hidden flex flex-col h-full transform transition-all hover:-translate-y-2 hover:shadow-2xl"
          data-aos="fade-up"
          data-aos-delay={index * 100 + 200}
        >
          <div class="relative aspect-video overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-primary-500/20 to-secondary-500/20 z-10"></div>
            <img 
              src={project.image} 
              alt={project.title}
              class="w-full h-full object-cover transform transition-transform hover:scale-105"
            />
            {project.featured && (
              <div class="absolute top-2 right-2 bg-primary-600 text-white px-2 py-1 text-xs font-medium rounded-full z-20">
                Featured
              </div>
            )}
          </div>
          
          <div class="p-6 flex flex-col flex-grow">
            <h3 class="text-xl font-bold mb-3 text-gray-900 dark:text-white">
              {project.title}
            </h3>
            
            <p class="text-gray-700 dark:text-gray-300 mb-4 flex-grow">
              {project.description}
            </p>
            
            <div class="flex flex-wrap gap-2 mb-4">
              {project.tags.map(tag => (
                <span class="text-xs px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-800 dark:text-gray-200 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
            
            <div class="flex gap-3 mt-2">
              <Button href={project.link} variant="primary" size="sm">
                View Project
              </Button>
              {project.github && (
                <Button href={project.github} variant="outline" size="sm" class="flex items-center">
                  <svg class="h-4 w-4 mr-1" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
                  </svg>
                  Code
                </Button>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</MainLayout>

<script>
  // Simple filtering functionality
  // This can be expanded with actual filtering logic
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.rounded-full');
    
    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        // Remove active class from all buttons
        filterButtons.forEach(b => {
          b.classList.remove('bg-primary-600');
          b.classList.remove('text-white');
          b.classList.add('bg-gray-200');
          b.classList.add('dark:bg-gray-800');
          b.classList.add('text-gray-800');
          b.classList.add('dark:text-gray-200');
        });
        
        // Add active class to clicked button
        button.classList.remove('bg-gray-200');
        button.classList.remove('dark:bg-gray-800');
        button.classList.remove('text-gray-800');
        button.classList.remove('dark:text-gray-200');
        button.classList.add('bg-primary-600');
        button.classList.add('text-white');
      });
    });
  });
</script>
